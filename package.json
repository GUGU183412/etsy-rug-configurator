{
  "name": "etsy-rug-configurator",
  "version": "1.0.0",
  "private": true,
  "description": "Etsy Custom Rug Online Configuration System",
  "type": "module",
  "scripts": {
    "dev:editor": "cd packages/editor && npm run dev",
    "dev:merchant": "cd packages/merchant-tool && npm run dev",
    "dev": "start scripts/start.bat",
    "build:shared": "cd packages/shared && npm run build",
    "build:editor": "cd packages/editor && npm run build",
    "build:merchant": "cd packages/merchant-tool && npm run build",
    "build:merchant:standalone": "cd packages/merchant-tool && npm run build:standalone",
    "build": "npm run build:shared && npm run build:editor && npm run build:merchant",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "keywords": ["etsy", "rug", "configurator", "pcx"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
